t><a:ext uri="{28A0092B-C50C-407E-A947-70E740481C1C}"><a14:useLocalDpi xmlns:a14="http://schemas.microsoft.com/office/drawing/2010/main" val="0"/></a:ext></a:extLst></a:blip><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr bwMode="auto"><a:xfrm><a:off x="0" y="0"/><a:ext cx="5274310" cy="2637155"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/><a:ln><a:noFill/></a:ln></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="7C43444C" w14:textId="77777777" w:rsidR="00B67ABC" w:rsidRPr="00B67ABC" w:rsidRDefault="00B67ABC" w:rsidP="00B67ABC"><w:pPr><w:pStyle w:val="a9"/><w:ind w:left="360"/><w:rPr><w:rFonts w:hint="eastAsia"/><w:b/><w:bCs/></w:rPr></w:pPr></w:p><w:p w14:paraId="5C25F46B" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>论文标题：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> Improvement of fault diagnosis efficiency in nuclear power plants using hybrid intelligence approach</w:t></w:r></w:p><w:p w14:paraId="371E8C68" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>对应主题：T2 (核电智能运维与故障诊断 / AI &amp; Fault Diagnosis)</w:t></w:r></w:p><w:p w14:paraId="29FD3BF6" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>主题贴合性：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> 摘要中明确出现了 fault diagnosis（故障诊断）、artificial neural network（人工神经网络）、data fusion（数据融合）等关键词，完全契合利用AI处理核电站数据的 T2 主题。</w:t></w:r></w:p><w:p w14:paraId="72F21F76" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>创新点：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> 提出了一种**“混合智能架构”**。它打破了单一算法的局限，根据诊断过程的进展，动态结合神经网络（黑盒数据驱动）、数据融合与符号有向图（白盒逻辑驱动），实现了对局部与全局复杂故障的自适应精准诊断。</w:t></w:r></w:p><w:p w14:paraId="4DADDC91" w14:textId="21DCB284" w:rsidR="006348F4" w:rsidRPr="00B67ABC" w:rsidRDefault="006348F4" w:rsidP="00B67ABC"><w:pPr><w:pStyle w:val="a9"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="9"/></w:numPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00B67ABC"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>文档 161.txt</w:t></w:r></w:p><w:p w14:paraId="7502233F" w14:textId="55FB487C" w:rsidR="00B67ABC" w:rsidRDefault="00B67ABC" w:rsidP="00B67ABC"><w:pPr><w:pStyle w:val="af2"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="9"/></w:numPr></w:pPr><w:r><w:rPr><w:rFonts w:hint="eastAsia"/><w:noProof/></w:rPr><w:lastRenderedPageBreak/><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="4EE9A8EB" wp14:editId="30235186"><wp:extent cx="5274310" cy="2637155"/><wp:effectExtent l="0" t="0" r="2540" b="0"/><wp:docPr id="1407936743" name="图片 2"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="Picture 4"/><pic:cNvPicPr><a:picLocks noChangeAspect="1" noChangeArrowheads="1"/></pic:cNvPicPr></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId8"><a:extLst><a:ext uri="{28A0092B-C50C-407E-A947-70E740481C1C}"><a14:useLocalDpi xmlns:a14="http://schemas.microsoft.com/office/drawing/2010/main" val="0"/></a:ext></a:extLst></a:blip><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr bwMode="auto"><a:xfrm><a:off x="0" y="0"/><a:ext cx="5274310" cy="2637155"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/><a:ln><a:noFill/></a:ln></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="3B1B5019" w14:textId="77777777" w:rsidR="00B67ABC" w:rsidRPr="00B67ABC" w:rsidRDefault="00B67ABC" w:rsidP="00B67ABC"><w:pPr><w:pStyle w:val="a9"/><w:ind w:left="360"/><w:rPr><w:rFonts w:hint="eastAsia"/><w:b/><w:bCs/></w:rPr></w:pPr></w:p><w:p w14:paraId="21F37354" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>论文标题：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> Molecular dynamics of single-particle impacts predicts phase diagrams for large scale pattern formation</w:t></w:r></w:p><w:p w14:paraId="139C3064" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>对应主题：T4 (核材料科学与辐照损伤 / Nuclear Materials &amp; Irradiation Damage)</w:t></w:r></w:p><w:p w14:paraId="69F91BC1" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>主题贴合性：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> 论文关注“高能粒子辐照 (Energetic particle irradiation)”以及“核反应堆和聚变堆面向等离子体壁的组件 (fusion reactor walls)”，与 T4 中的 irradiation、ion、damage、materials 完全对应。</w:t></w:r></w:p><w:p w14:paraId="14AABA7F" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>创新点：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> </w:t></w:r><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>颠覆了传统认知。</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> 过去学术界认为材料表面在离子轰击下产生纳米图案或降解，是因为靶原子的“溅射侵蚀 (sputter erosion)”；但这篇论文通过无参数分子动力学模拟证明，核心机制其实是</w:t></w:r><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>未被溅射走的靶原子的撞击重分布</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t>，溅射侵蚀的影响无关紧要。这为核材料的抗辐照设计提供了全新的理论标准。</w:t></w:r></w:p><w:p w14:paraId="74C14584" w14:textId="531A1DEA" w:rsidR="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">3. 文档 </w:t></w:r></w:p><w:p w14:paraId="33DE7EDC" w14:textId="77777777" w:rsidR="00B67ABC" w:rsidRPr="006348F4" w:rsidRDefault="00B67ABC" w:rsidP="006348F4"><w:pPr><w:rPr><w:rFonts w:hint="eastAsia"/><w:b/><w:bCs/></w:rPr></w:pPr></w:p><w:p w14:paraId="3594DFAD" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>论文标题：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> Cooperativity among defect sites in AO2+x and A4O9 (A=U,Np,Pu): Density functional calculations</w:t></w:r></w:p><w:p w14:paraId="2B55BA1A" w14:textId="1ECBE5B6" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>对应主题：T7 (核燃料与反应堆堆芯 / Fuel &amp; Reactor Core)</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> </w:t></w:r></w:p><w:p w14:paraId="12D15183" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>主题贴合性：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> 研究对象是铀(U)、镎(Np)和钚(Pu)的二氧化物（AO2），这些是典型的核反应堆燃料（nuclear reactor fuels），涉及晶格缺陷和氧化问题。</w:t></w:r></w:p><w:p w14:paraId="0330CECF" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>创新点：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> 运用密度泛函理论(DFT)计算，揭示了处于氧化环境下的核燃料内部**“氧团簇形成的协同效应”**。论文预测了一种被称为“分裂双间隙(split di-interstitial)”的结构是最稳定的团簇基本构建块，并从原子轨道杂化(O 2p orbitals)的微观角度解释了燃料氧化的热力学机制。</w:t></w:r></w:p><w:p w14:paraId="027A81DE" w14:textId="7E4710F0" w:rsidR="006348F4" w:rsidRPr="00B67ABC" w:rsidRDefault="006348F4" w:rsidP="00B67ABC"><w:pPr><w:pStyle w:val="a9"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="9"/></w:numPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00B67ABC"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>文档 97.txt</w:t></w:r></w:p><w:p w14:paraId="110A4214" w14:textId="1B07B2C0" w:rsidR="00B67ABC" w:rsidRDefault="00B67ABC" w:rsidP="00B67ABC"><w:pPr><w:pStyle w:val="af2"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="9"/></w:numPr></w:pPr><w:r><w:rPr><w:rFonts w:hint="eastAsia"/><w:noProof/></w:rPr><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="33D86E3F" wp14:editId="3B2F2769"><wp:extent cx="5274310" cy="2637155"/><wp:effectExtent l="0" t="0" r="2540" b="0"/><wp:docPr id="750395708" name="图片 5"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="Picture 16"/><pic:cNvPicPr><a:picLocks noChangeAspect="1" noChangeArrowheads="1"/></pic:cNvPicPr></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId9"><a:extLst><a:ext uri="{28A0092B-C50C-407E-A947-70E740481C1C}"><a14:useLocalDpi xmlns:a14="http://schemas.microsoft.com/office/drawing/2010/main" val="0"/></a:ext></a:extLst></a:blip><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr bwMode="auto"><a:xfrm><a:off x="0" y="0"/><a:ext cx="5274310" cy="2637155"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/><a:ln><a:noFill/></a:ln></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="3CA0C234" w14:textId="77777777" w:rsidR="00B67ABC" w:rsidRPr="00B67ABC" w:rsidRDefault="00B67ABC" w:rsidP="00B67ABC"><w:pPr><w:pStyle w:val="a9"/><w:ind w:left="360"/><w:rPr><w:rFonts w:hint="eastAsia"/><w:b/><w:bCs/></w:rPr></w:pPr></w:p><w:p w14:paraId="30D4CAA3" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>论文标题：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> Surface functionalization graphene oxide by polydopamine for high affinity of radionuclides</w:t></w:r></w:p><w:p w14:paraId="6E6EA766" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:lastRenderedPageBreak/><w:t>对应主题：T9 (放射性化学——吸附与去污 / Adsorption &amp; Radiochemistry)</w:t></w:r></w:p><w:p w14:paraId="2618E499" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>主题贴合性：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> 摘要中多次提及“去除水溶液中的铀(VI)” (remove uranium(VI))、“放射性核素” (radionuclides) 和“吸附能力” (adsorption capacity)，完美契合 T9 主题。</w:t></w:r></w:p><w:p w14:paraId="240694D4" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>创新点：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> 采用了一种</w:t></w:r><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>仿生表面功能化工艺</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t>。作者在氧化石墨烯(GO)表面通过多巴胺的自聚合，合成了一种新型二维纳米复合材料 (PD/GO)。该材料结合了多巴胺的多功能基团和石墨烯的超高比表面积（协同效应），实现了高达 145.39 mg/g 的极高铀吸附容量，并证明了其在核废液处理中的可长期再生性。</w:t></w:r></w:p><w:p w14:paraId="2B885B4A" w14:textId="44E17EFC" w:rsidR="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">5. 文档 </w:t></w:r></w:p><w:p w14:paraId="52361092" w14:textId="10A95FB8" w:rsidR="00B67ABC" w:rsidRPr="00B67ABC" w:rsidRDefault="00B67ABC" w:rsidP="00B67ABC"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00B67ABC"><w:rPr><w:rFonts w:hint="eastAsia"/><w:b/><w:bCs/></w:rPr><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="566DED51" wp14:editId="035C8D67"><wp:extent cx="5274310" cy="2637155"/><wp:effectExtent l="0" t="0" r="2540" b="0"/><wp:docPr id="597719334" name="图片 7"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="Picture 23"/><pic:cNvPicPr><a:picLocks noChangeAspect="1" noChangeArrowheads="1"/></pic:cNvPicPr></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId10"><a:extLst><a:ext uri="{28A0092B-C50C-407E-A947-70E740481C1C}"><a14:useLocalDpi xmlns:a14="http://schemas.microsoft.com/office/drawing/2010/main" val="0"/></a:ext></a:extLst></a:blip><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr bwMode="auto"><a:xfrm><a:off x="0" y="0"/><a:ext cx="5274310" cy="2637155"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/><a:ln><a:noFill/></a:ln></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="4FED7BF1" w14:textId="77777777" w:rsidR="00B67ABC" w:rsidRPr="006348F4" w:rsidRDefault="00B67ABC" w:rsidP="006348F4"><w:pPr><w:rPr><w:rFonts w:hint="eastAsia"/><w:b/><w:bCs/></w:rPr></w:pPr></w:p><w:p w14:paraId="2922EA4B" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="5"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>论文标题：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> Heat transfer with laminar pulsating flow in a channel or tube in rolling motion</w:t></w:r></w:p><w:p w14:paraId="3B8312DE" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="5"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>对应主题：T10 (反应堆热工水力学 / Reactor Thermal-Hydraulics)</w:t></w:r></w:p><w:p w14:paraId="2E779D66" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="5"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:lastRenderedPageBreak/><w:t>主题贴合性：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> 关键词包括“传热” (Heat transfer)、“层流脉动流” (laminar pulsating flow) 和核动力系统 (nuclear power systems)，属于典型的热工水力学流体研究。</w:t></w:r></w:p><w:p w14:paraId="3DDE2839" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="5"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>创新点：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> 专门针对</w:t></w:r><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>海洋环境下的核动力系统（如核潜艇或海上浮动核电站）</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t>。论文建立了一个在**“摇摆运动 (rolling motion)”**状态下管道内部脉动流的传热模型，并指出经典的 Nield &amp; Kuznetsov 静止环境理论不再适用于这种动态海洋环境，填补了船舶核动力热工水力的特定理论空白。</w:t></w:r></w:p><w:p w14:paraId="0EB9E834" w14:textId="62E42BD7" w:rsidR="006348F4" w:rsidRPr="00B67ABC" w:rsidRDefault="006348F4" w:rsidP="00B67ABC"><w:pPr><w:pStyle w:val="a9"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="9"/></w:numPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00B67ABC"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">文档 </w:t></w:r></w:p><w:p w14:paraId="074AFD4D" w14:textId="43792F84" w:rsidR="00B67ABC" w:rsidRPr="00B67ABC" w:rsidRDefault="00B67ABC" w:rsidP="00B67ABC"><w:pPr><w:pStyle w:val="af2"/><w:ind w:left="360"/><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:hint="eastAsia"/><w:noProof/></w:rPr><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="1951F812" wp14:editId="0512E247"><wp:extent cx="5274310" cy="2637155"/><wp:effectExtent l="0" t="0" r="2540" b="0"/><wp:docPr id="298072453" name="图片 9"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="Picture 27"/><pic:cNvPicPr><a:picLocks noChangeAspect="1" noChangeArrowheads="1"/></pic:cNvPicPr></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId11"><a:extLst><a:ext uri="{28A0092B-C50C-407E-A947-70E740481C1C}"><a14:useLocalDpi xmlns:a14="http://schemas.microsoft.com/office/drawing/2010/main" val="0"/></a:ext></a:extLst></a:blip><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr bwMode="auto"><a:xfrm><a:off x="0" y="0"/><a:ext cx="5274310" cy="2637155"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/><a:ln><a:noFill/></a:ln></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="0D0DD009" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="6"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>论文标题：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> Some lessons learned from the development and updating processes of the probabilistic safety assessments of Daya Bay nuclear power plant</w:t></w:r></w:p><w:p w14:paraId="65F2A523" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="6"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>对应主题：T13 (概率安全评价 / Probabilistic Safety Assessment, PSA)</w:t></w:r></w:p><w:p w14:paraId="28B60E93" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="6"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:lastRenderedPageBreak/><w:t>主题贴合性：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> 标题与摘要直指核心关键词“概率安全评价” (probabilistic safety assessment, PSA)。</w:t></w:r></w:p><w:p w14:paraId="6B59F597" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="6"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>创新点：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> 偏向</w:t></w:r><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>工程应用与方法论创新</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t>。它没有空谈理论模型，而是基于中国大亚湾核电站的真实工程实践，总结了在开发和“动态更新”PSA模型过程中的经验教训。文章强调 PSA 模型不能为了建而建，必须与决策应用需求紧密结合，为中国乃至全球核电站的风险管理落地提供了极具价值的工程指导。</w:t></w:r></w:p><w:p w14:paraId="752F9A0A" w14:textId="0EC7F6B2" w:rsidR="006348F4" w:rsidRPr="00B67ABC" w:rsidRDefault="006348F4" w:rsidP="00B67ABC"><w:pPr><w:pStyle w:val="a9"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="9"/></w:numPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00B67ABC"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">文档 </w:t></w:r></w:p><w:p w14:paraId="40758C98" w14:textId="627F5624" w:rsidR="00B67ABC" w:rsidRDefault="00B67ABC" w:rsidP="00B67ABC"><w:pPr><w:pStyle w:val="af2"/></w:pPr><w:r><w:rPr><w:rFonts w:hint="eastAsia"/><w:noProof/></w:rPr><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="5F7FAF50" wp14:editId="06C22E85"><wp:extent cx="5274310" cy="2637155"/><wp:effectExtent l="0" t="0" r="2540" b="0"/><wp:docPr id="1100949770" name="图片 8"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="Picture 25"/><pic:cNvPicPr><a:picLocks noChangeAspect="1" noChangeArrowheads="1"/></pic:cNvPicPr></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId12"><a:extLst><a:ext uri="{28A0092B-C50C-407E-A947-70E740481C1C}"><a14:useLocalDpi xmlns:a14="http://schemas.microsoft.com/office/drawing/2010/main" val="0"/></a:ext></a:extLst></a:blip><a:srcRect/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr bwMode="auto"><a:xfrm><a:off x="0" y="0"/><a:ext cx="5274310" cy="2637155"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/><a:ln><a:noFill/></a:ln></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="0A115A1A" w14:textId="77777777" w:rsidR="00B67ABC" w:rsidRPr="00B67ABC" w:rsidRDefault="00B67ABC" w:rsidP="00B67ABC"><w:pPr><w:pStyle w:val="a9"/><w:ind w:left="360"/><w:rPr><w:rFonts w:hint="eastAsia"/><w:b/><w:bCs/></w:rPr></w:pPr></w:p><w:p w14:paraId="3E3558F6" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="7"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>论文标题：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> Design of a management information system for the Shielding Experimental Reactor ageing management</w:t></w:r></w:p><w:p w14:paraId="1FA29B6D" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="7"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>对应主题：T27 (宏观核电安全管理 / Safety Management &amp; Design)</w:t></w:r></w:p><w:p w14:paraId="3C317811" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="7"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>主题贴合性：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> 关注“核反应堆老化管理” (reactor ageing management)、“定期安全审查” (periodic safety review) 和信息系</w:t></w:r><w:r w:rsidRPr="006348F4"><w:lastRenderedPageBreak/><w:t>统。</w:t></w:r></w:p><w:p w14:paraId="50D80B5A" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="006348F4" w:rsidP="006348F4"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="7"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>创新点：</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> 针对</w:t></w:r><w:r w:rsidRPr="006348F4"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>研究型反应堆 (research reactors)</w:t></w:r><w:r w:rsidRPr="006348F4"><w:t xml:space="preserve"> 老化管理专业软件匮乏的痛点，开发了一套基于Web的全新管理信息系统（SERAMIS）。该系统利用 J2EE 三层架构和 MVC 模型，将设备数据检索、安全审查法规参考和结构组件(SSCs)的分类方法固化到软件流程中，极大提升了研究堆的安全管理效率。</w:t></w:r></w:p><w:p w14:paraId="0B385A1C" w14:textId="77777777" w:rsidR="006348F4" w:rsidRPr="006348F4" w:rsidRDefault="00000000" w:rsidP="006348F4"><w:pPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r><w:pict w14:anchorId="6A199F76"><v:rect id="_x0000_i1025" style="width:0;height:1.5pt" o:hralign="center" o:hrstd="t" o:hr="t" fillcolor="#a0a0a0" stroked="f"/></w:pict></w:r></w:p><w:p w14:paraId="5442FE8A" w14:textId="77777777" w:rsidR="00B67ABC" w:rsidRDefault="00B67ABC" w:rsidP="006348F4"/><w:p w14:paraId="233E23A0" w14:textId="03D9C40E" w:rsidR="00A500E3" w:rsidRDefault="00A500E3" w:rsidP="006348F4"><w:pPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>Us_only</w:t></w:r></w:p><w:p w14:paraId="6E9C8CFF" w14:textId="5131F03A" w:rsidR="00A500E3" w:rsidRDefault="00A500E3" w:rsidP="00A500E3"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00A500E3"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>该论文的核心创新点 (Innovations)</w:t></w:r></w:p><w:p w14:paraId="16103ED2" w14:textId="661B9542" w:rsidR="00B67ABC" w:rsidRPr="00A500E3" w:rsidRDefault="00B67ABC" w:rsidP="00A500E3"><w:pPr><w:rPr><w:rFonts w:hint="eastAsia"/><w:b/><w:bCs/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:hint="eastAsia"/><w:b/><w:bCs/></w:rPr><w:t>对应主题T21</w:t></w:r><w:r w:rsidR="00FC35BC"><w:rPr><w:rFonts w:hint="eastAsia"/><w:b/><w:bCs/></w:rPr><w:t>（切尔诺贝利事件相关研究）</w:t></w:r></w:p><w:p w14:paraId="06D9FB51" w14:textId="77777777" w:rsidR="00A500E3" w:rsidRPr="00A500E3" w:rsidRDefault="00A500E3" w:rsidP="00A500E3"><w:pPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="00A500E3"><w:t>在2008年左右，科学家虽然已经观察到某些真菌能在切尔诺贝利等极强辐射区“繁荣生长”，但对其背后的具体机制了解并不透彻。这篇论文的创新点在于</w:t></w:r><w:r w:rsidRPr="00A500E3"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>从宏观现象深入到了微观物理化学机制的定量分析</w:t></w:r><w:r w:rsidRPr="00A500E3"><w:t>：</w:t></w:r></w:p><w:p w14:paraId="738AFC75" w14:textId="77777777" w:rsidR="00A500E3" w:rsidRPr="00A500E3" w:rsidRDefault="00A500E3" w:rsidP="00A500E3"><w:pPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="00A500E3"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>1. 明确提出了“物理屏蔽+化学猝灭”的双重防护假说并加以证实</w:t></w:r></w:p><w:p w14:paraId="360410E3" w14:textId="77777777" w:rsidR="00A500E3" w:rsidRPr="00A500E3" w:rsidRDefault="00A500E3" w:rsidP="00A500E3"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="8"/></w:numPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r w:rsidRPr="00A500E3"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>创新突破：</w:t></w:r><w:r w:rsidRPr="00A500E3"><w:t xml:space="preserve"> 过去可能认为黑色素仅仅像一面“物理盾牌”挡住辐射。但这篇论文提出并验证了，黑色素对微生物的辐射防护是**物理屏蔽（包括康普顿散射）</w:t></w:r><w:r w:rsidRPr="00A500E3"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>和</w:t></w:r><w:r w:rsidRPr="00A500E3"><w:t>化学猝灭（吸收并中和辐射产生的致命自由基）**共同作用的结果。</w:t></w:r></w:p><w:p w14:paraId="045F498B" w14:textId="77777777" w:rsidR="00A500E3" w:rsidRPr="00A500E3" w:rsidRDefault="00A500E3" w:rsidP="006348F4"><w:pPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr></w:p><w:p w14:paraId="020D65B9" w14:textId="77777777" w:rsidR="00B90D23" w:rsidRPr="006348F4" w:rsidRDefault="00B90D23"><w:pPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr></w:p><w:sectPr w:rsidR="00B90D23" w:rsidRPr="006348F4"><w:pgSz w:w="11906" w:h="16838"/><w:pgMar w:top="1440" w:right="1800" w:bottom="1440" w:left="1800" w:header="851" w:footer="992" w:gutter="0"/><w:cols w:space="425"/><w:docGrid w:type="lines" w:linePitch="312"/></w:sectPr></w:body></w:document>